# ===== Agente NCS — serviço (copie p/ .env e preencha no Portainer como variáveis) =====
PORT=8080

# Modelo (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODEL=google/gemini-2.5-flash

# Octadesk (chave da aba "Tokens API Octadesk" — já temos uma no .env do projeto)
OCTADESK_BASE_URL=https://o222276-30e.api002.octadesk.services
OCTADESK_API_KEY=
# subdomínio da conta (aparece na URL do Octadesk) — usado no external-webhook
OCTADESK_SUBDOMAIN=o222276-30e
# e-mail do "agente" que assina as ações (header octa-agent-email)
OCTADESK_AGENT_EMAIL=

# Superlógica (SOMENTE LEITURA no piloto — regenerar p/ usuário de serviço antes de produção)
SUPERLOGICA_BASE_URL=https://api.superlogica.net/v2/condor
SUPERLOGICA_APP_TOKEN=
SUPERLOGICA_ACCESS_TOKEN=

# Segredo compartilhado: o Octadesk manda esse valor no header pra provar que é ele.
# Cadastre o MESMO valor em Octadesk > Tokens Externos (ex.: agente-ncs-token) e use no fluxo.
WEBHOOK_SECRET=

# Segurança operacional
DRY_RUN_WRITES=true      # nunca escreve no Superlógica (piloto = só leitura)
LOG_PII=false            # nunca logar CPF/boleto/valor cru
